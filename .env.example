# ──────────────────────────────────────────────────────────────
# Audiobook Forge — Environment Variables
# Copy to .env and fill in values as needed.
# ──────────────────────────────────────────────────────────────

# Cloud OpenAI-compatible API key (only if using cloud TTS or cloud LLM)
OPENAI_API_KEY=

# Fish Audio API key (only if using Fish Audio cloud API instead of local)
FISH_AUDIO_API_KEY=

# LLM API key for emotion tagging (only if using cloud LLM endpoint)
EMOTION_LLM_API_KEY=
